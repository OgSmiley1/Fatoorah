# SESSION_SECRET: A random string for session encryption
SESSION_SECRET=

# TELEGRAM_BOT_TOKEN: Required for Telegram remote control.
TELEGRAM_BOT_TOKEN=

# =========================================================
# FREE AI PROVIDERS
# The app works end-to-end with zero paid keys.
# DuckDuckGo scraper is always active (no key needed).
# =========================================================

# OLLAMA_URL: Local Ollama instance for free unlimited AI script generation
# Primary engine for outreach script generation.
# Install: https://ollama.ai/ — then run: ollama pull llama3.2
# Default: http://localhost:11434
OLLAMA_URL=

# OLLAMA_MODEL: Which Ollama model to use for script generation
# Default: llama3.2
OLLAMA_MODEL=

# GROQ_API_KEY: Groq free-tier API — fast LLM inference at no cost
# Used for merchant discovery and script generation fallback.
# Sign up (free): https://console.groq.com/
# Models used: llama-3.3-70b-versatile
GROQ_API_KEY=

# OPENROUTER_API_KEY: OpenRouter free-model access
# Used for merchant discovery and script generation fallback.
# Sign up (free): https://openrouter.ai/ — select ":free" suffix models
# Models used: meta-llama/llama-3.1-8b-instruct:free
OPENROUTER_API_KEY=

# =========================================================
# PAID AI PROVIDERS (optional — enable for extra coverage)
# These are only used when their API key is present.
# =========================================================

# GEMINI_API_KEY: Google Gemini AI with Google Search grounding (paid)
# Sign up: https://aistudio.google.com/
GEMINI_API_KEY=

# PPLX_API_KEY: Perplexity AI with sonar web-search model (paid)
# Sign up: https://docs.perplexity.ai/
PPLX_API_KEY=

# XAI_API_KEY: Grok AI (xAI) with web search capabilities (paid)
# Sign up: https://console.x.ai/
XAI_API_KEY=
